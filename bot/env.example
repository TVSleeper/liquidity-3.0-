# Copy this file to ../.env or bot/.env and fill values.
# Never commit a real private key.

# Keeper hot wallet private key. This wallet pays gas and triggers rebalance only.
BOT_PRIVATE_KEY=

# Main wallet that can pause the strategy and withdraw tokens/NFT.
OWNER_ADDRESS=

# Optional. Defaults to bot wallet address.
KEEPER_ADDRESS=

RPC_URL=https://bsc-mainnet.public.blastapi.io
POOL_ID=0x1c0195a12979e395d956a9e2581ef720b925b2a7cc1c60a5b82d9fc0fc564ffa

# Fill these after npm run bot:deploy.
EXECUTOR_ADDRESS=
STRATEGY_ADDRESS=
# Set true only when deploying a fresh upgraded executor even if EXECUTOR_ADDRESS is already present.
FORCE_NEW_EXECUTOR=false

# Range mode:
# below = keep liquidity below price as USDT
# above = keep liquidity above price as NES
# auto = falling tick -> below/USDT, rising tick -> above/NES
SIDE=below
AUTO_INITIAL_SIDE=below
OFFSET_PERCENT=0.2

# Bot loop and safety.
CHECK_SECONDS=3
SLIPPAGE_BPS=50
# 0 means the bot will not block removal because the pool composition changed.
REMOVE_MIN_BPS=0
MINT_SAFETY_PERCENT=98
# Small max-spend headroom for PancakeSwap rounding during mint. It does not create extra funds.
MINT_MAX_BUFFER_BPS=5
REBALANCE_ON_UNWANTED_ASSET=true
REBALANCE_TICK_THRESHOLD=0
MAX_TICK_WIDTH=1000
MAX_GAS_GWEI=0
MIN_LIQUIDITY=1
DEADLINE_SECONDS=1200
RECOVERY_SCAN_LIMIT=500

# Start in dry-run mode. Set false only after checking logs.
DRY_RUN=true
RUN_ONCE=false
